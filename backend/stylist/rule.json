    {
        "room_type": "bedroom",
        "selection_guidance": {
            "intent": "balanced, functional, restful, uncluttered",
            "use_all_objects": false,
            "cluster_templates": [
                {
                    "cluster_id": "sleep_core",
                    "priority": "core",
                    "selection_rule": "must_include",
                    "pick_rules": {
                        "required_all_of": [
                            "bed"
                        ],
                        "optional_from": [
                            "nightstand"
                        ],
                        "max_keep": {
                            "nightstand": 2,
                            "bench": 1
                        }
                    },
                    "notes": [
                        "The bed must remain the dominant anchor.",
                        "Nightstands are useful support objects but should be limited.",
                        "A bench is optional and should only be kept if it improves completeness without clutter."
                    ]
                },
                {
                    "cluster_id": "storage_core",
                    "priority": "core",
                    "selection_rule": "must_include",
                    "pick_rules": {
                        "at_least_one_of": [
                            "wardrobe",
                            "dresser"
                        ],
                        "optional_from": [
                            "bookshelf",
                            "storage_cabinet"
                        ],
                        "optional_at_most": 1
                    },
                    "notes": [
                        "Keep at least one strong storage anchor.",
                        "Only one additional storage/display support object should be added."
                    ]
                },
                {
                    "cluster_id": "work_study",
                    "priority": "support",
                    "selection_rule": "may_include_if_useful",
                    "pick_rules": {
                        "required_all_of_if_kept": [
                            "desk"
                        ],
                        "exactly_one_of_if_kept": [
                            "chair",
                            "office_chair"
                        ],
                        "optional_from": [
                            "bookshelf"
                        ]
                    },
                    "notes": [
                        "Only include this cluster if the brief implies study, work, or multi-use bedroom behavior.",
                        "Keep just one desk seat."
                    ]
                },
                {
                    "cluster_id": "lounge_reading",
                    "priority": "support",
                    "selection_rule": "may_include_if_useful",
                    "pick_rules": {
                        "required_all_of_if_kept": [
                            "armchair"
                        ],
                        "optional_from": [
                            "side_table",
                            "floor_lamp"
                        ],
                        "optional_at_most": 2
                    },
                    "notes": [
                        "Use this as a quiet secondary relaxation zone.",
                        "Do not create this cluster if the room already feels crowded."
                    ]
                },
                {
                    "cluster_id": "media_optional",
                    "priority": "optional",
                    "selection_rule": "may_include_if_useful",
                    "conditional_rules": [
                        {
                            "if": "brief_mentions_tv_or_media",
                            "required_all_of": [
                                "tv_console"
                            ]
                        }
                    ],
                    "notes": [
                        "Only include media furniture when the brief explicitly supports it."
                    ]
                },
                {
                    "cluster_id": "utility_optional",
                    "priority": "optional",
                    "selection_rule": "may_include_if_useful",
                    "conditional_rules": [
                        {
                            "if": "brief_mentions_laundry_or_daily_storage",
                            "optional_from": [
                                "laundry_basket"
                            ]
                        }
                    ],
                    "notes": [
                        "Utility items should be included only when justified."
                    ]
                }
            ],
            "global_selection_rules": [
                {
                    "type": "dominant_anchor_required",
                    "object": "bed"
