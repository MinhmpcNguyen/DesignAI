                    "objects": [
                        "bookshelf",
                        "storage_cabinet"
                    ],
                    "max_keep": 1
                },
                {
                    "type": "max_keep_from_group",
                    "objects": [
                        "chair",
                        "office_chair"
                    ],
                    "max_keep": 1
                },
                {
                    "type": "max_keep_from_group",
                    "objects": [
                        "armchair"
                    ],
                    "max_keep": 1
                },
                {
